#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./_nvm-load.sh
source "$SCRIPT_DIR/_nvm-load.sh"
# shellcheck source=./_pkgm.sh
source "$SCRIPT_DIR/_pkgm.sh"

if [ "$PKGM_BIN" != "pnpm" ]; then
  echo "✗ pnpm is required for CI." >&2
  exit 1
fi

echo "🧪 Running quality checks with $PKGM_PRETTY_NAME"
shoebox_pkgm_install_ci
shoebox_pkgm_run validate:data
shoebox_pkgm_run test
shoebox_pkgm_run build
shoebox_pkgm_run check:output
