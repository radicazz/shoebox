#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./_nvm-load.sh
source "$SCRIPT_DIR/_nvm-load.sh"

if [ ! -s dist/index.html ]; then
  echo "✗ dist/index.html is missing or empty" >&2
  exit 1
fi

MAX_BYTES=$((16 * 1024 * 1024))
DIST_BYTES=$(du -sb dist | cut -f1)
if [ "$DIST_BYTES" -gt "$MAX_BYTES" ]; then
  echo "✗ dist exceeds the 16 MiB budget ($(du -sh dist | cut -f1))" >&2
  exit 1
fi

echo "✓ dist output is within the 16 MiB budget ($(du -sh dist | cut -f1))"
